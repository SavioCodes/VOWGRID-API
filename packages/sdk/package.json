{
  "name": "@vowgrid/sdk",
  "version": "0.1.0",
  "description": "TypeScript client SDK for the VowGrid API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SavioCodes/VOWGRID-API.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vowgrid/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
