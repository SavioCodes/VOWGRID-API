VOWGRID_POSTGRES_USER=vowgrid
VOWGRID_POSTGRES_PASSWORD=replace-me
VOWGRID_POSTGRES_DB=vowgrid
VOWGRID_API_IMAGE=ghcr.io/your-org/vowgrid-api:latest
VOWGRID_WEB_IMAGE=ghcr.io/your-org/vowgrid-web:latest
VOWGRID_WEB_BASE_URL=https://app.example.com
VOWGRID_PRIMARY_DOMAIN=app.example.com
VOWGRID_ACTIVE_SLOT=blue
# Optional managed data stores.
# Leave blank to use the bundled Postgres/Redis services from docker-compose.bluegreen.yml.
VOWGRID_DATABASE_URL=
VOWGRID_REDIS_URL=
VOWGRID_API_ENV_FILE=./api.env.example
VOWGRID_WEB_ENV_FILE=./web.env.example
