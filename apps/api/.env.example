# --------------------------------------------------------------------------
# VowGrid - API Environment Variables
# Copy this file to apps/api/.env for local development
# --------------------------------------------------------------------------

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://vowgrid:vowgrid_dev@localhost:5432/vowgrid?schema=public

# Redis
REDIS_URL=redis://localhost:6379
APP_WEB_BASE_URL=http://localhost:3000

# Auth
SESSION_SECRET=change-me-in-production
API_KEY_SALT=change-me-in-production
AUDIT_LOG_HMAC_KEY=
CONNECTOR_CONFIG_ENCRYPTION_KEY=

# Email delivery
MAIL_FROM_EMAIL=noreply@vowgrid.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# OAuth providers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Billing / Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_WEBHOOK_URL=
MERCADO_PAGO_RETURN_URL=http://localhost:3000/app/billing
BILLING_DEFAULT_TAX_RATE_BPS=0
BILLING_BR_CPF_TAX_RATE_BPS=0
BILLING_BR_CNPJ_TAX_RATE_BPS=0
BILLING_COUPON_CATALOG_JSON=
# Example:
# BILLING_COUPON_CATALOG_JSON=[{"code":"LAUNCH10","label":"Launch 10%","kind":"percent","percentOffBps":1000}]

# Metrics
METRICS_AUTH_TOKEN=
SENTRY_DSN=
SLACK_ALERT_WEBHOOK_URL=
DATADOG_LOGS_API_KEY=
DATADOG_SITE=datadoghq.com
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_LOGS_URL=https://log-api.newrelic.com/log/v1

# Rate Limiting
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# API key lifecycle
API_KEY_DEFAULT_TTL_DAYS=90
API_KEY_MAX_TTL_DAYS=365

# Browser / CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
