# --------------------------------------------------------------------------
# VowGrid - API Environment Variables
# Copy this file to apps/api/.env for local development
# --------------------------------------------------------------------------

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://vowgrid:vowgrid_dev@localhost:5432/vowgrid?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
API_KEY_SALT=change-me-in-production

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
