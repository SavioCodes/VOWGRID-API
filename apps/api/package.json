{
  "name": "@vowgrid/api",
  "version": "0.1.0",
  "private": true,
  "description": "VowGrid API - Trust layer backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "pnpm exec prisma generate",
    "typecheck": "pnpm --filter @vowgrid/contracts build && tsc --noEmit",
    "lint": "pnpm run typecheck",
    "test": "vitest run",
    "test:unit": "vitest run src/modules/*/__tests__/*.test.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "migrate": "prisma migrate dev",
    "migrate:reset": "prisma migrate reset --force",
    "generate": "pnpm exec prisma generate",
    "seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@vowgrid/contracts": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/client": "^6.4.1",
    "bullmq": "^5.34.8",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.3",
    "ioredis": "^5.4.2",
    "nanoid": "^5.1.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  }
}
