# API environment for local development
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

DATABASE_URL=postgresql://vowgrid:vowgrid_dev@localhost:5432/vowgrid?schema=public
# Managed providers can also populate:
# POSTGRES_PRISMA_URL=postgres://...
# POSTGRES_URL_NON_POOLING=postgres://...
REDIS_URL=redis://localhost:6379
APP_WEB_BASE_URL=http://localhost:3000

SESSION_SECRET=change-me-in-development
API_KEY_SALT=change-me-in-development

MAIL_FROM_EMAIL=noreply@vowgrid.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_WEBHOOK_URL=
MERCADO_PAGO_RETURN_URL=http://localhost:3000/app/billing
BILLING_DEFAULT_TAX_RATE_BPS=0
METRICS_AUTH_TOKEN=

RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000
